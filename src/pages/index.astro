---
import Contact from "@/components/home/Contact.astro"
import Hero from "@/components/home/Hero.astro"
import Showcase from "@/components/home/Showcase.astro"
import { SAME_AS_LINKS } from "@/constants/links"
import { PROFILE } from "@/constants/profile"
import RootLayout from "@/layouts/RootLayout.astro"
import type { ProfilePage, WithContext } from "schema-dts"

const pageTitle = `${PROFILE.name} - ${PROFILE.title}`
const pageDescription = PROFILE.bio

const jsonLd: WithContext<ProfilePage> = {
  "@context": "https://schema.org",
  "@type": "ProfilePage",
  name: pageTitle,
  description: pageDescription,
  url: Astro.url.toString(),
  mainEntity: {
    "@type": "Person",
    name: PROFILE.name,
    alternateName: PROFILE.nickname,
    jobTitle: PROFILE.title,
    image: PROFILE.photo.src,
    nationality: { "@type": "Country", name: PROFILE.country },
    email: PROFILE.email,
    telephone: PROFILE.phone,
    url: PROFILE.website,
    sameAs: SAME_AS_LINKS,
    birthDate: PROFILE.birthDate,
    gender: PROFILE.gender,
    knowsLanguage: PROFILE.languages.map((language) => language.code),
  },
}
---

<RootLayout title={pageTitle} description={pageDescription}>
  <Hero />
  <main class="flex flex-col gap-y-20 py-20">
    <Showcase />
    <Contact />
  </main>
  <script
    slot="json-ld"
    type="application/ld+json"
    is:inline
    set:html={JSON.stringify(jsonLd)}
  />
</RootLayout>
