---
import ProfileCard from "@/components/links/ProfileCard.astro"
import ProfileLinksList from "@/components/links/ProfileLinksList.astro"
import { SAME_AS_LINKS } from "@/constants/links"
import { PROFILE } from "@/constants/profile"
import RootLayout from "@/layouts/RootLayout.astro"
import type { ProfilePage, WithContext } from "schema-dts"

const pageTitle = `Links - ${PROFILE.name}`
const pageDescription =
  "Find all my social media profiles and contact information in one place."

const jsonLd: WithContext<ProfilePage> = {
  "@context": "https://schema.org",
  "@type": "ProfilePage",
  name: pageTitle,
  description: pageDescription,
  url: Astro.url.toString(),
  mainEntity: {
    "@type": "Person",
    name: PROFILE.name,
    alternateName: PROFILE.nickname,
    jobTitle: PROFILE.title,
    image: PROFILE.photo.src,
    nationality: { "@type": "Country", name: PROFILE.country },
    email: PROFILE.email,
    telephone: PROFILE.phone,
    url: PROFILE.website,
    sameAs: SAME_AS_LINKS,
    birthDate: PROFILE.birthDate,
    gender: PROFILE.gender,
    knowsLanguage: PROFILE.languages.map((language) => language.code),
  },
}
---

<RootLayout title={pageTitle} description={pageDescription}>
  <ProfileCard />
  <main class="container max-w-2xl py-4">
    <ProfileLinksList />
  </main>
  <script
    slot="json-ld"
    type="application/ld+json"
    is:inline
    set:html={JSON.stringify(jsonLd)}
  />
</RootLayout>
