---
import type { ProfileLink } from "@/constants/links"
import { cn } from "@/lib/utils"
import { ArrowUpRight } from "lucide-react"
import { buttonVariants } from "../ui/button"

interface Props {
  links: ProfileLink[]
}

const { links } = Astro.props
---

<ul role="list" class="space-y-2">
  {
    links.map(({ name, link, icon: Icon, handle, subtitle, external }) => (
      <li>
        <a
          href={link}
          target={external ? "_blank" : undefined}
          rel={external ? "noreferrer" : undefined}
          class={cn(
            buttonVariants({ variant: "outline" }),
            "w-full gap-4 px-4 sm:gap-5 sm:px-5",
          )}
        >
          <Icon className="size-8 relative -top-px" aria-hidden />
          <span class="inline-flex flex-1 flex-col overflow-hidden">
            <span>{name}</span>
            {(handle || subtitle) && (
              <span class="text-muted-foreground truncate text-sm">
                {handle ?? subtitle}
              </span>
            )}
          </span>
          {external && (
            <ArrowUpRight
              className="text-muted-foreground size-5"
              aria-hidden
            />
          )}
        </a>
      </li>
    ))
  }
</ul>
