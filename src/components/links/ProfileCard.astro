---
import { Image } from "astro:assets"
import { PROFILE } from "@/constants/profile"
import Iso from "../Iso.astro"

const { name, title, photo } = PROFILE
const photoAlt = `Portrait of ${name}`
---

<header class="container mt-24 max-w-2xl">
  <div
    class="from-background to-primary/20 relative flex items-center gap-4 overflow-hidden border bg-linear-to-r px-4 py-4 sm:px-5"
  >
    <Iso
      aria-hidden
      class="animate-draw absolute right-4 z-10 size-44 opacity-25 [stroke-dasharray:1000]"
    />
    <Image
      src={photo}
      alt={photoAlt}
      class="bg-background z-10 size-16 rounded-full border-2 object-cover object-top sm:size-20"
      loading="eager"
    />
    <div class="z-10 flex-1">
      <h1 class="text-xl font-bold text-balance sm:text-2xl">{name}</h1>
      <p class="text-muted-foreground text-sm sm:text-base">{title}</p>
    </div>
  </div>
</header>
