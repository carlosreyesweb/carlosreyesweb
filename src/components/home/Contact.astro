---
import { PROFILE } from "@/constants/profile"
import { parsePhoneNumber } from "@/lib/utils"
import Iso from "../Iso.astro"
import SocialLinks from "../SocialLinks.astro"
import { Anchor } from "../ui/anchor"
import { Separator } from "../ui/separator"
import { Typography } from "../ui/typography"
---

<section
  class="container grid max-w-7xl grid-cols-1 gap-8 py-20 md:grid-cols-2"
>
  <hgroup
    class="flex max-w-3xl flex-col gap-y-4 text-center text-balance md:text-left"
  >
    <Typography variant="h2" id="contact"
      >Let's <span class="text-primary">Build Something Great</span></Typography
    >
    <Typography variant="p">
      Ready to level up your software project? Contact me to work with an expert
      who knows the full stack.
    </Typography>
    <SocialLinks class="mx-auto md:mx-0" />
  </hgroup>
  <address
    class="relative h-min font-mono not-italic sm:border sm:px-8 sm:py-6 lg:text-lg"
  >
    {PROFILE.name}
    <br />
    {PROFILE.title}
    <br />
    <div class="text-muted-foreground">
      404 Not Found Lane, <br />
      CSS Grid City, JS 12345, <br />
      The Internet <br />
    </div>
    <Separator className="my-2" />
    Email: <span class="text-primary font-medium whitespace-nowrap"
      >{PROFILE.email}</span
    >
    <br />
    WhatsApp: <Anchor
      href={`https://wa.me/${parsePhoneNumber(PROFILE.phone)}`}
      className="whitespace-nowrap">{PROFILE.phone}</Anchor
    >
    <br />
    Website: <Anchor href={PROFILE.website} className="whitespace-nowrap"
      >www.carlosreyesweb.com</Anchor
    >
    <Iso class="fill-primary absolute top-6 right-6 hidden w-8 sm:block" />
  </address>
</section>
